# EditorConfig keeps whitespace consistent across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Dart's formatter owns the 80-column wrap; mirror it for editors that read this.
[*.dart]
max_line_length = 80

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml,json}]
indent_size = 2

# Generated localization sources — left as the tool emits them.
[lib/l10n/gen/**]
trim_trailing_whitespace = false
insert_final_newline = false
