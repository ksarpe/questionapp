# Standard Flutter iOS Podfile. Committed (rather than letting Flutter generate a
# default on each build) solely so the post_install hook below can run — see the
# ITMS-91064 block at the bottom.
platform :ios, '13.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # ---------------------------------------------------------------------------
  # ITMS-91064 mitigation.
  # Apple rejects any embedded PrivacyInfo.xcprivacy that declares tracking
  # domains (NSPrivacyTrackingDomains non-empty) while NSPrivacyTracking is not
  # true. A bundled third-party SDK (the Google Ads family — the only pods here
  # that list tracking domains) ships such an inconsistent manifest. Walk every
  # pod manifest, log its state, and flip NSPrivacyTracking=true wherever
  # domains are declared. Truthful: if an SDK lists tracking domains, tracking
  # is in fact happening. plutil handles both XML and binary plists. Runs on the
  # Codemagic Mac during `flutter build ipa`'s pod install.
  # ---------------------------------------------------------------------------
  pods_dir = File.join(File.dirname(File.realpath(__FILE__)), 'Pods')
  Dir.glob(File.join(pods_dir, '**', '*.xcprivacy')).sort.each do |manifest|
    has_domain = system("/usr/bin/plutil -extract NSPrivacyTrackingDomains.0 raw \"#{manifest}\" >/dev/null 2>&1")
    tracking = `/usr/bin/plutil -extract NSPrivacyTracking raw "#{manifest}" 2>/dev/null`.strip
    rel = manifest.sub(pods_dir + '/', '')
    puts "[privacy] #{rel} — trackingDomains?=#{has_domain} NSPrivacyTracking=#{tracking.empty? ? 'absent' : tracking}"
    if has_domain && tracking != 'true'
      if system("/usr/bin/plutil -replace NSPrivacyTracking -bool true \"#{manifest}\"")
        puts "[privacy]   ↳ ITMS-91064 FIX: set NSPrivacyTracking=true"
      else
        puts "[privacy]   ↳ WARNING: could not patch #{rel}"
      end
    end
  end
end
