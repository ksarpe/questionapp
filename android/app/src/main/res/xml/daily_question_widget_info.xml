<?xml version="1.0" encoding="utf-8"?>
<!-- Metadata for the daily-question home-screen widget. Default 2x2, resizeable.
     updatePeriodMillis is a light 6h re-render of whatever the app last pushed
     (no background network — see the plan); the freshest data arrives when the
     app is opened. previewLayout / targetCell* apply on Android 12+ and are
     ignored on older versions. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:maxResizeWidth="320dp"
    android:maxResizeHeight="220dp"
    android:updatePeriodMillis="21600000"
    android:initialLayout="@layout/daily_question_widget"
    android:previewLayout="@layout/daily_question_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen" />
