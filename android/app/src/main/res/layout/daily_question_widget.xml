<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen widget: black "sticker" card with today's daily question.
     The label and question text are filled in by DailyQuestionWidgetProvider
     from data the Flutter app pushes (WidgetSyncService). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:textColor="#F97316"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/widget_question"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fontFamily="@font/anton_regular"
        android:textColor="#FFFFFF"
        android:gravity="top|start"
        android:maxLines="6"
        android:ellipsize="end"
        android:lineSpacingMultiplier="0.95"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="15sp"
        android:autoSizeMaxTextSize="30sp"
        android:autoSizeStepGranularity="1sp" />
</LinearLayout>
